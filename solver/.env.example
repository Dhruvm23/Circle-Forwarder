# ═══════════════════════════════════════════════════════════════
#  Circle Forwarder — Solver Engine Environment Configuration
# ═══════════════════════════════════════════════════════════════

# RPC Endpoints (required)
BASE_RPC_URL=https://mainnet.base.org
ARB_RPC_URL=https://arb1.arbitrum.io/rpc

# Solver Wallet (required — NEVER commit real keys)
SOLVER_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# Deployed Contract Addresses (required)
BASE_RECEIVER_ADDRESS=0x_DEPLOYED_BASE_RECEIVER_ADDRESS
ARB_EXECUTOR_ADDRESS=0x_DEPLOYED_ARB_EXECUTOR_ADDRESS

# Polling Configuration (optional — defaults shown)
POLLING_INTERVAL_MS=5000
